import discord
import asyncio
from discord.ext import commands

Token =""



client = commands.Bot(command_prefix="!", self_bot=True)

active_loops = {}
freedom_user_id = None
freedom_granted = False
@client.event
async def on_ready():
    print(f"Logged in as {client.user}")


@client.event
async def on_message(message):
    global freedom_user_id, freedom_granted

    if message.author.bot:
        return


    # -----------------------
    # START COMMAND
    # -----------------------
    if message.content.startswith("!start"):
        if message.channel.id in active_loops:
            await message.reply("A loop is already running here!")
            return

        if not message.mentions:
            await message.reply("Mention a user. Example: !start @user")
            return

        target = message.mentions[0]
        starter = message.author
        count = 0
        max_messages = 5

        async def tag_loop():
            nonlocal count
            try:
                while count < max_messages:
                    await message.channel.send(
                        f"{target.mention} — {starter.name} tagged you!"
                    )
                    count += 1
                    await asyncio.sleep(5)
            except asyncio.CancelledError:
                pass
            finally:
                active_loops.pop(message.channel.id, None)

        task = asyncio.create_task(tag_loop())
        active_loops[message.channel.id] = {
            "task": task,
            "starter_id": starter.id
        }

    # -----------------------
    # GRANT FREEDOM (ONE TIME)
    # -----------------------
    if message.content.startswith("!grantfreedom"):
        if freedom_granted:
            await message.reply("Freedom already granted once.")
            return

        if not message.mentions:
            await message.reply("Mention a user to grant freedom.")
            return

        freedom_user_id = message.mentions[0].id
        freedom_granted = True
        await message.channel.send("Freedom granted (one-time).")

    # -----------------------
    # STOP COMMAND
    # -----------------------
    if message.content.lower() == "!stop":
        loop_data = active_loops.get(message.channel.id)
        if not loop_data:
            return

        if (
            message.author.id != loop_data["starter_id"]
            and message.author.id != freedom_user_id
        ):
            await message.reply("You don't have permission to stop this loop.")
            return

        loop_data["task"].cancel()
        active_loops.pop(message.channel.id, None)
        await message.channel.send("Loop stopped.")

    # -----------------------
    # TAG ROLE COMMAND
    # -----------------------
    if message.content.startswith("!tagrole"):
        if not message.role_mentions:
            await message.reply("Mention a role. Example: !tagrole @Members")
            return

        role = message.role_mentions[0]

        await message.channel.send(
            content=f"{role.mention}",
            allowed_mentions=discord.AllowedMentions(roles=True)
        )


client.run(TOKEN)









